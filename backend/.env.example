APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clouddrive
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=["http://localhost:3000"]
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/tmp/cloud-drive-storage
MAX_UPLOAD_SIZE_BYTES=104857600
DEFAULT_USER_QUOTA_BYTES=16106127360

# Email / password-reset delivery.
# EMAIL_PROVIDER=console logs the reset password to the server log (default, no setup).
# EMAIL_PROVIDER=smtp sends real email — fill in the SMTP_* values below.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USERNAME=your@gmail.com,
# SMTP_PASSWORD=<16-char App Password> (not your normal password; requires 2FA).
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Cloud Drive <no-reply@clouddrive.local>
SMTP_USE_TLS=true
