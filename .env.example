# ─────────────────────────────────────────────────────────────────────────────
# Cloud Drive — deployment config. Copy to `.env` and adjust as needed.
#
#   cp .env.example .env && docker compose up --build
#
# Every value has a working default, so an empty .env still boots. The only
# value you SHOULD change for anything but local dev is JWT_SECRET_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports (host side) ────────────────────────────────────────────────────────
FRONTEND_PORT=8088        # open http://localhost:8088 after `up`
BACKEND_PORT=8000         # API; the frontend proxies /api to it internally
POSTGRES_PORT=5432

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=cloud_drive
POSTGRES_USER=cloud_drive
POSTGRES_PASSWORD=cloud_drive_dev   # change for any shared/public deployment

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate one with:  openssl rand -hex 32
# (scripts/start.sh fills this automatically when it first creates .env.)
JWT_SECRET_KEY=development-only-change-me

# Browsers load the SPA from the frontend and call /api on the SAME origin
# (nginx proxies it to the backend), so CORS normally isn't exercised. These
# origins only matter if you point a dev frontend straight at the backend.
CORS_ORIGINS=["http://localhost:8088","http://127.0.0.1:8088","http://localhost:5173"]

# Where the built frontend sends API calls. Leave as the relative default so it
# works on any host; only set an absolute URL if the API lives elsewhere.
VITE_API_BASE_URL=/api/v1

# ── Time Machine ─────────────────────────────────────────────────────────────
# In-process snapshot scheduler. Safe with the single-worker container; for a
# multi-worker deployment turn this off and drive snapshots via external cron.
SNAPSHOT_SCHEDULER_ENABLED=true

# ── AI Assistant (optional) ──────────────────────────────────────────────────
# Needs a reachable Ollama server. If you don't have one, set ASSISTANT_ENABLED
# to false — everything else (files, sharing, search, Time Machine) still works.
ASSISTANT_ENABLED=true
LLM_PROVIDER=ollama
# host.docker.internal reaches an Ollama running on the host machine.
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=ollama-local
ASSISTANT_MODEL=gemma3:12b
LLM_NUM_CTX=65536
LLM_TIMEOUT_SECONDS=300
LLM_KEEP_ALIVE=15m

# ── Semantic search (optional) ───────────────────────────────────────────────
# Meaning-based file search. Needs an embedding model pulled in Ollama
# (`ollama pull nomic-embed-text`). Off by default; keyword + full-text search
# work regardless. EMBEDDING_BASE_URL defaults to LLM_BASE_URL when empty.
# If you change EMBEDDING_MODEL, its output dimension must match the vector
# column width (768) in migration 0012.
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=

# ── External model upgrade (optional, DEC-026) ───────────────────────────────
# When the local model repeatedly fails, the assistant can fall back to GPT-5.5
# using each user's own OpenAI API key (set in Settings). Encryption key is
# REQUIRED to enable per-user credentials; generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty = per-user credentials disabled (the feature is simply off).
CREDENTIAL_ENCRYPTION_KEY=
EXTERNAL_API_BASE_URL=https://api.openai.com/v1
EXTERNAL_CHAT_MODEL=gpt-5.5
# Path A (Codex subscription, EM3): the official `codex` CLI binary used to bridge a
# user's subscription. Only needed if users set Codex credentials; build the backend
# image with --build-arg INSTALL_CODEX=1 to include it.
CODEX_BIN=codex
